<mxfile host="app.diagrams.net">
  <diagram id="agentcore-mv-director-migrated" name="architecture-agentcore">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1320" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Frames ===== -->
        <mxCell id="awscloud" value="AWS Cloud" style="sketch=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud_alt;container=0;collapsible=0;strokeColor=#232F3E;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;fontSize=12;html=1;" vertex="1" parent="1">
