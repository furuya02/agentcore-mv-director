        <!-- ===== Legend ===== -->
        <mxCell id="legend" value="凡例： ① 入力  ② Bedrockで絵コンテ＋作詞  ③④ 外部生成API（fal/ElevenLabs）  ⑤⑥ Code Interpreterで結合・S3出力（緑）  破線: 補助（キー/トレース）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CCCCCC;fontColor=#333333;align=left;spacingLeft=10;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
