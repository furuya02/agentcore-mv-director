          <mxGeometry x="210" y="110" width="740" height="560" as="geometry" />
        </mxCell>
        <mxCell id="agentcore" value="Amazon Bedrock AgentCore" style="rounded=1;dashed=1;strokeColor=#01A88D;fillColor=none;verticalAlign=top;align=left;spacingLeft=12;fontColor=#01A88D;fontSize=12;html=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="150" width="680" height="380" as="geometry" />
