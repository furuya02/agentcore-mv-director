# 実APIを叩く場合のみ設定。未設定なら自動でドライラン（課金なし）。
FAL_KEY=
ELEVENLABS_API_KEY=
# 強制ドライラン
# DRY_RUN=1
# 出力先（既定: output）
# OUTPUT_DIR=output
# 完成MVのアップロード先 S3 バケット（未設定ならローカルのみ）
# S3_BUCKET=agentcore-mv-director-20260623
# ffmpeg の実体パス（zsh の alias は subprocess から見えない。例: /Applications/ffmpeg）
# FFMPEG_BIN=/Applications/ffmpeg
